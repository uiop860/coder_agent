{
  "terminal.integrated.profiles.windows": {
    "PowerShellWithStartup": {
      "path": "pwsh",
      "args": [
        "-NoExit",
        "-File",
        "${workspaceFolder}/.vscode/terminal_startup.ps1"
      ]
    }
  },
  "terminal.integrated.defaultProfile.windows": "PowerShellWithStartup",
  "github.copilot.chat.commitMessageGeneration.instructions": [
    {
      "file": ".github/commit-instructions.md"
    }
  ]
}
